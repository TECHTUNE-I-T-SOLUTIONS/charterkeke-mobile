{
  "expo": {
    "name": "Charter Keke",
    "slug": "charter-keke-mobile",
    "version": "2.1.8",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/charter keke.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/charter keke.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "plugins": [
      [
        "expo-router",
        {}
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.24.2"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermissions": "Allow Charter Keke to access your location even when you aren't using the app"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/charter keke.png",
          "color": "#1a1a1a",
          "modes": [
            "production"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Charter Keke to access your camera"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/charter keke.png"
    },
    "scheme": "charterkeke",
    "assetBundlePatterns": [
      "assets/**"
    ],
    "ios": {
      "icon": "./assets/ios-app-icon-1024.png",
      "bundleIdentifier": "com.charterkeke.mobile",
      "buildNumber": "19",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "location"
        ],
        "NSLocationWhenInUseUsageDescription": "Charter Keke needs your location to match you with nearby rides",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Charter Keke needs your location for live tracking",
        "NSLocationAlwaysUsageDescription": "Charter Keke needs your location during active rides to support trip tracking and safety.",
        "NSCameraUsageDescription": "Charter Keke needs camera access for profile pictures and KYC",
        "NSPhotoLibraryUsageDescription": "Allow Charter Keke to access your photos",
        "NSPhotoLibraryAddUsageDescription": "Allow Charter Keke to save ride-related images to your photo library when you choose to."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/charter keke.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.charterkeke.mobile",
      "versionCode": 8,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9966caa5-2d6e-4192-a97c-0eb0f3108fa0"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/9966caa5-2d6e-4192-a97c-0eb0f3108fa0"
    }
  }
}

{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "staging",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "MAPBOX_DOWNLOADS_TOKEN": "$MAPBOX_SECRET_TOKEN"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "MAPBOX_DOWNLOADS_TOKEN": "$MAPBOX_SECRET_TOKEN"
      }
    }
  },
  "submit": {
    "production": {}
  },
  "update": {
    "enabled": true,
    "codeSigningCertificate": "./certs/code-signing-cert.pem",
    "codeSigningMetadata": {
      "keyid": "main",
      "alg": "rsa-sha256"
    },
    "url": "https://u.expo.dev/9966caa5-2d6e-4192-a97c-0eb0f3108fa0"
  }
}

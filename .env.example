# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_TIMEOUT=30000

# Maps Configuration (Mapbox Native SDK)
EXPO_PUBLIC_MAPBOX_API_KEY=pk.YOUR_PUBLIC_TOKEN
MAPBOX_SECRET_KEY=sk.YOUR_SECRET_TOKEN

# App Configuration
EXPO_PUBLIC_APP_NAME=Charter Keke
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_BUILD_VERSION=1
EXPO_PUBLIC_APP_LINK=https://charterkeke.vercel.app/app/install

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true

# Cache Configuration
EXPO_PUBLIC_CACHE_EXPIRY_MINUTES=30
EXPO_PUBLIC_SYNC_INTERVAL_SECONDS=300

# Notification Configuration
EXPO_PUBLIC_NOTIFICATION_CHANNEL=charter-keke-notifications

# ========================================
# Payment Processing (Paystack)
# ========================================
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ========================================
# SMS Gateway (Termii)
# ========================================
EXPO_PUBLIC_TERMII_API_KEY=
EXPO_PUBLIC_TERMII_SENDER_ID=charter_keke

# ========================================
# Database (Supabase)
# ========================================
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ========================================
# Push Notifications (VAPID Keys)
# ========================================
EXPO_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

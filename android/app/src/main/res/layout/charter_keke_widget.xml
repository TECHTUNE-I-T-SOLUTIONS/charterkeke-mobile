<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#121212"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
      android:id="@+id/widget_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/widget_title"
      android:textColor="#FFFFFF"
      android:textSize="16sp"
      android:textStyle="bold"
      android:layout_marginBottom="2dp" />

    <TextView
      android:id="@+id/widget_subtitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/widget_subtitle"
      android:textColor="#BDBDBD"
      android:textSize="12sp"
      android:layout_marginBottom="10dp" />

    <TextView
      android:id="@+id/widget_section_one_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Recent routes"
      android:textColor="#FFFFFF"
      android:textSize="13sp"
      android:textStyle="bold"
      android:layout_marginBottom="6dp" />

    <LinearLayout
      android:id="@+id/widget_section_one_rows"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <LinearLayout
        android:id="@+id/widget_rider_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B1B1B"
        android:padding="10dp"
        android:layout_marginBottom="6dp">

        <TextView
          android:id="@+id/widget_rider_title_1"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_rider_subtitle_1"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#BDBDBD"
          android:textSize="11sp"
          android:layout_marginTop="2dp" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/widget_rider_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B1B1B"
        android:padding="10dp"
        android:layout_marginBottom="6dp">

        <TextView
          android:id="@+id/widget_rider_title_2"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_rider_subtitle_2"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#BDBDBD"
          android:textSize="11sp"
          android:layout_marginTop="2dp" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/widget_rider_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B1B1B"
        android:padding="10dp">

        <TextView
          android:id="@+id/widget_rider_title_3"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_rider_subtitle_3"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#BDBDBD"
          android:textSize="11sp"
          android:layout_marginTop="2dp" />
      </LinearLayout>
    </LinearLayout>

    <TextView
      android:id="@+id/widget_section_two_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Driver rides"
      android:textColor="#FFFFFF"
      android:textSize="13sp"
      android:textStyle="bold"
      android:layout_marginTop="10dp"
      android:layout_marginBottom="6dp" />

    <LinearLayout
      android:id="@+id/widget_section_two_rows"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <LinearLayout
        android:id="@+id/widget_driver_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B1B1B"
        android:padding="10dp"
        android:layout_marginBottom="6dp">

        <TextView
          android:id="@+id/widget_driver_title_1"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_driver_subtitle_1"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#BDBDBD"
          android:textSize="11sp"
          android:layout_marginTop="2dp" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/widget_driver_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B1B1B"
        android:padding="10dp"
        android:layout_marginBottom="6dp">

        <TextView
          android:id="@+id/widget_driver_title_2"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_driver_subtitle_2"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#BDBDBD"
          android:textSize="11sp"
          android:layout_marginTop="2dp" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/widget_driver_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B1B1B"
        android:padding="10dp">

        <TextView
          android:id="@+id/widget_driver_title_3"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_driver_subtitle_3"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#BDBDBD"
          android:textSize="11sp"
          android:layout_marginTop="2dp" />
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginTop="10dp">

      <Button
        android:id="@+id/widget_primary_action"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/widget_primary_action"
        android:backgroundTint="#FF9101"
        android:textColor="#000000" />

      <Space
        android:layout_width="8dp"
        android:layout_height="1dp" />

      <Button
        android:id="@+id/widget_secondary_action"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/widget_secondary_action"
        android:backgroundTint="#2A2A2A"
        android:textColor="#FFFFFF" />
    </LinearLayout>
  </LinearLayout>
</ScrollView>
